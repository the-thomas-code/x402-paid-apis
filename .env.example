# Environment Variables

# Server Configuration
PORT=3000
NODE_ENV=development

# x402 Facilitator Configuration
# Use Coinbase CDP for production: https://api.cdp.coinbase.com/platform/v2/x402
# Use public test facilitator for development: https://x402.org/facilitator
FACILITATOR_URL=https://x402.org/facilitator

# Your wallet address to receive payments (Base Sepolia testnet)
# Generate a new wallet for testing: https://www.myetherwallet.com/
PAYMENT_ADDRESS=0x0000000000000000000000000000000000000000

# Network: Use base-sepolia for testing, base for mainnet
NETWORK=base-sepolia

# Coinbase CDP API Key (only needed for production/mainnet)
# Get yours at: https://portal.cdp.coinbase.com/
CDP_API_KEY_NAME=
CDP_API_KEY_PRIVATE=
